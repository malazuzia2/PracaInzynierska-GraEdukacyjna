  levelName: Two Pillars
  startingCodeHint: "-- Goal: Build two yellow pillars.\r\n-- This code builds only
    the LEFT pillar at x = -2.\r\n-- How can you change the 'if' statement\r\n--
    to ALSO build the RIGHT pillar at x = 2?\r\n\r\nfunction PlaceVoxel(x, y, z)\r\n 
    local color = 0\r\n  \r\n  if x == -2 and z == 0 and y >= 0 and y < 4 then\r\n   
    color = 4\r\n  end\r\n  \r\n  return color\r\nend"
  referenceShape:
  - position: {x: -2, y: 0, z: 0}
    blockType: 4
  - position: {x: -2, y: 1, z: 0}
    blockType: 4
  - position: {x: -2, y: 2, z: 0}
    blockType: 4
  - position: {x: -2, y: 3, z: 0}
    blockType: 4
  - position: {x: 2, y: 0, z: 0}
    blockType: 4
  - position: {x: 2, y: 1, z: 0}
    blockType: 4
  - position: {x: 2, y: 2, z: 0}
    blockType: 4
  - position: {x: 2, y: 3, z: 0}
    blockType: 4
