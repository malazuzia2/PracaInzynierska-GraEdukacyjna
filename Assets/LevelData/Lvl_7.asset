  levelName: 'The Hollow Box '
  startingCodeHint: "-- Goal: Build a yellow pyramid.\r\n-- The height (y) depends
    on distance from center (math.abs).\r\n\r\nfunction PlaceVoxel(x, y, z)\r\n 
    local color = 0\r\n  \r\n  -- Calculate how far we are from center \r\n  local
    dist = math.abs(x) + math.abs(z)\r\n  \r\n  -- TODO: Calculate targetY based
    on 'dist'.\r\n  -- The pyramid goes DOWN, so it should be negative distance.\r\n 
    local targetY = 0 \r\n  \r\n  if y == targetY and y >= -4 then\r\n    color =
    4\r\n  end\r\n  \r\n  return color\r\nend"
  solutionCode: "function PlaceVoxel(x, y, z)\r\n    local color = 0\r\n    local
    targetY = -(math.abs(x) + math.abs(z))\r\n    \r\n    if y == targetY and y >=
    -4 then\r\n        color = 4 -- \u017B\xF3\u0142ty\r\n    end\r\n    \r\n   
    return color\r\nend"
