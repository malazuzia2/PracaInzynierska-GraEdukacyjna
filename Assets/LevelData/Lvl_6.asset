    local color = 0\r\n  \r\n  if y == -4 then\r\n    -- TODO: Check if x is divisible
    by 2 (remainder is 0)\r\n    -- if x % 2 == 0 then ...\r\n    \r\n    color =
    0 -- Change this inside your 'if'\r\n  end\r\n  \r\n  return color\r\nend"
  solutionCode: "function PlaceVoxel(x, y, z)\r\n    local color = 0\r\n    \r\n   
    if y == -4 and x % 2 == 0 then\r\n        color = 2 -- Zielony\r\n    end\r\n   
    \r\n    return color\r\nend"
