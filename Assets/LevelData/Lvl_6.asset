  levelName: Checkerboard
  startingCodeHint: "-- Goal: Create a checkerboard pattern.\r\n-- This code builds
    a solid red floor.\r\n-- Change it to use an 'if/else' statement with the\r\n--
    modulo operator '%' to choose between red (1) and blue (3).\r\n-- Hint: if (x
    + z) % 2 == 0 then ...\r\n\r\nfunction PlaceVoxel(x, y, z)\r\n  local color =
    0\r\n  \r\n  if y == 0 then\r\n    -- This part needs an if/else block!\r\n   
    color = 1 \r\n  end\r\n  \r\n  return color\r\nend"
  referenceShape:
  - position: {x: -1, y: 0, z: -1}
    blockType: 1
  - position: {x: -1, y: 0, z: 0}
    blockType: 3
  - position: {x: -1, y: 0, z: 1}
    blockType: 1
  - position: {x: 0, y: 0, z: -1}
    blockType: 3
  - position: {x: 0, y: 0, z: 0}
    blockType: 1
  - position: {x: 0, y: 0, z: 1}
    blockType: 3
  - position: {x: 1, y: 0, z: -1}
    blockType: 1
  - position: {x: 1, y: 0, z: 0}
    blockType: 3
  - position: {x: 1, y: 0, z: 1}
    blockType: 1
