  m_Script: {fileID: 11500000, guid: 5d5b11ce4dce9be49be43102afff5e06, type: 3}
  m_Name: Lvl_5
  m_EditorClassIdentifier: Assembly-CSharp::LevelData
  levelName: A Pillar with a Hat
  startingCodeHint: "-- Goal: Build a red pillar with a green block on top.\r\n--
    This code builds a 4-block high red pillar.\r\n-- Add a NEW 'if' statement AFTER
    this one to\r\n-- change the color of just the top block (y=3) to green.\r\n\r\nfunction
    PlaceVoxel(x, y, z)\r\n  local color = 0\r\n  \r\n  if x == 0 and z == 0 and
    y >= 0 and y < 4 then\r\n    color = 1 -- Red\r\n  end\r\n  \r\n  -- Add your
    new 'if' statement here to place the \"hat\"!\r\n  \r\n  return color\r\nend"
  referenceShape:
  - position: {x: 0, y: 0, z: 0}
    blockType: 1
  - position: {x: 0, y: 1, z: 0}
    blockType: 1
  - position: {x: 0, y: 2, z: 0}
    blockType: 1
  - position: {x: 0, y: 3, z: 0}
    blockType: 2
