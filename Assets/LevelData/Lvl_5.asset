  m_EditorClassIdentifier: Assembly-CSharp::LevelData
  levelName: Two sides
  startingCodeHint: "-- Goal: Left side (x < 0) is Red (1). Right side (x > 0) is
    Blue (3).\r\n\r\nfunction PlaceVoxel(x, y, z)\r\n  local color = 0\r\n  \r\n 
    if x < 0 then\r\n    color = 1\r\n  -- TODO: Add an 'elseif' block here to check
    if x > 0\r\n  -- and set color to 3.\r\n  end\r\n  \r\n  return color\r\nend"
  solutionCode: "function PlaceVoxel(x, y, z)\r\n    local color = 0\r\n    \r\n   
    if x < 0 then\r\n        color = 1 -- Czerwony\r\n    elseif x > 0 then\r\n       
    color = 3 -- Niebieski\r\n    end\r\n    \r\n    return color\r\nend"
