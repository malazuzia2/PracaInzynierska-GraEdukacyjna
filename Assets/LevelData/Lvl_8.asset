  m_Name: Lvl_8
  m_EditorClassIdentifier: Assembly-CSharp::LevelData
  levelName: Pyramid
  startingCodeHint: "-- Goal: Build a solid blue sphere (radius 3).\r\n-- Math Hint:
    x*x + y*y + z*z = distance squared.\r\n\r\nfunction PlaceVoxel(x, y, z)\r\n 
    local color = 0\r\n  local radiusSquared = 9 -- (3 * 3)\r\n  \r\n  -- Calculate
    current distance squared\r\n  local myDistSquared = (x * x) + (y * y) + (z *
    z)\r\n  \r\n  -- TODO: Check if myDistSquared is less than or equal to radiusSquared\r\n 
    if myDistSquared == 0 then -- Fix this condition\r\n    color = 3\r\n  end\r\n 
    \r\n  return color\r\nend"
  solutionCode: "function PlaceVoxel(x, y, z)\r\n    local color = 0\r\n    \r\n   
    if (x * x) + (y * y) + (z * z) <= 9 then\r\n        color = 3 -- Niebieski\r\n   
    end\r\n    \r\n    return color\r\nend"
