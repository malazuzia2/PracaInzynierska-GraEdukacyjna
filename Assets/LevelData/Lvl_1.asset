  levelName: The First Cube
  startingCodeHint: "-- Goal: Build a single red block at the center (0, 0, 0).\r\n--
    The 'if' statement below checks the coordinates.\r\n-- Inside the 'if', you need
    to change the value of 'color'.\r\n\r\nfunction PlaceVoxel(x, y, z)\r\n  local
    color = 0\r\n  \r\n  if x == 0 and y == 0 and z == 0 then\r\n    -- Change this
    line to place a red block (type 1)\r\n    color = 0 \r\n  end\r\n  \r\n  return
    color\r\nend"
  referenceShape:
  - position: {x: 0, y: 0, z: 0}
    blockType: 1
